#!/bin/bash

there_get_first_where_result() {
    local tool_name="$1"
    local first_result

    first_result="$(where "$tool_name" 2>/dev/null | head -n 1)"

    if [[ -z "$first_result" || "$first_result" == *' not found' ]]; then
        printf 'Error: Tool "%s" does not exist.\n' "$tool_name" >&2
        return 2
    fi

    printf '%s\n' "$first_result"
}