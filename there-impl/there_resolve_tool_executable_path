#!/bin/bash

there_resolve_tool_executable_path() {
    local tool_name="$1"
    local wrapper_path
    local wrapper_contents
    local candidate_path
    local found_candidate=false

    wrapper_path="$(there_get_first_where_result "$tool_name")" || return $?
    there_validate_wrapper_file "$wrapper_path" || return $?

    wrapper_contents="$(cat "$wrapper_path")" || {
        printf 'Error: Failed to read wrapper file: %s\n' "$wrapper_path" >&2
        return 5
    }

    while IFS= read -r candidate_path; do
        [[ -z "$candidate_path" ]] && continue
        found_candidate=true

        if [[ -f "$candidate_path" ]]; then
            printf '%s\n' "$candidate_path"
            return 0
        fi
    done < <(
        printf '%s\n' "$wrapper_contents" |
            grep -oE '"[^"]+\.exe"' |
            tr -d '"' |
            awk '!seen[$0]++'
    )

    if ! $found_candidate; then
        printf 'Error: No executable paths were found in wrapper file: %s\n' "$wrapper_path" >&2
        return 6
    fi

    printf 'Error: No executable path from wrapper exists on this system: %s\n' "$wrapper_path" >&2
    return 7
}