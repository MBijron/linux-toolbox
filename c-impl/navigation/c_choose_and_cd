#!/bin/bash

c_choose_and_cd() {
    local results="$1"
    local preferred_index="$2"
    local open_in_code="$3"
    local open_in_vs="$4"
    local chosen_path

    if [[ "$open_in_code" != "1" ]]; then
        open_in_code="0"
    fi
    if [[ "$open_in_vs" != "1" ]]; then
        open_in_vs="0"
    fi

    if [[ -z "$results" ]]; then
        echo "No matching repository found."
        return 1
    fi

    chosen_path="$(c_choose_path "$results" "$preferred_index")" || return 1

    if [[ "$open_in_code" == "1" ]]; then
        code "$chosen_path" || return 1
    elif [[ "$open_in_vs" == "1" ]]; then
        vs "$chosen_path" || return 1
    else
        cd "$chosen_path" || return 1
    fi

    return 0
}