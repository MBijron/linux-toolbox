#!/bin/bash

unalias include_windows_command >/dev/null 2>&1 || true

include_windows_command() {
  local shim_file="$(__tb_windows_shim_list_path)"
  local refresh_cache="0"
  local arg=""
  local command_name=""
  local line=""
  local existing_line=""
  local shim_target=""
  local shim_present="0"
  local -a requested_commands=()
  local -a commands_to_add=()

  if [ "$#" -eq 0 ]; then
    printf 'Usage: include_windows_command [--refresh-cache] <command> [command ...]\n' >&2
    return 1
  fi

  mkdir -p "$TBDIR/links"
  touch "$shim_file"

  for arg in "$@"; do
    case "$arg" in
      -r|--refresh-cache)
        refresh_cache="1"
        ;;
      -help|--help)
        printf 'Usage: include_windows_command [--refresh-cache] <command> [command ...]\n'
        return 0
        ;;
      -*)
        printf 'Unknown option: %s\n' "$arg" >&2
        return 1
        ;;
      *)
        command_name="$(__tb_add_to_path_normalize_command_name "$arg")"

        if [ -n "$command_name" ] && ! __tb_add_to_path_array_contains "$command_name" "${requested_commands[@]}"; then
          requested_commands+=("$command_name")
        fi
        ;;
    esac
  done

  if [ "$refresh_cache" = "1" ]; then
    __tb_add_to_path --refresh-cache || return 1
    printf 'Windows PATH cache refreshed\n'
  fi

  if [ "${#requested_commands[@]}" -eq 0 ]; then
    if [ "$refresh_cache" = "1" ]; then
      return 0
    fi

    printf 'Usage: include_windows_command [--refresh-cache] <command> [command ...]\n' >&2
    return 1
  fi

  __tb_windows_path_load_cache
  if [ -z "$__tb_windows_cached_path" ] || [ "$refresh_cache" = "1" ]; then
    __tb_add_to_path --refresh-cache || return 1
    __tb_windows_path_load_cache
  fi

  for command_name in "${requested_commands[@]}"; do
    shim_target="$(__tb_windows_shim_target_name "$command_name" "$__tb_windows_cached_path")"

    if [ -z "$shim_target" ]; then
      printf '%s shim not created because %s.exe, %s.bat, or %s.cmd was not found\n' "$command_name" "$command_name" "$command_name" "$command_name"
      continue
    fi

    if ! __tb_add_to_path_array_contains "$command_name" "${commands_to_add[@]}"; then
      commands_to_add+=("$command_name")
    fi
  done

  for command_name in "${commands_to_add[@]}"; do
    shim_present="0"

    while IFS= read -r line || [ -n "$line" ]; do
      existing_line="$(__tb_add_to_path_normalize_command_name "$line")"

      if [ "$existing_line" = "$command_name" ]; then
        shim_present="1"
        break
      fi
    done < "$shim_file"

    if [ "$shim_present" = "1" ]; then
      printf '%s shim not added because it is already in the list\n' "$command_name"
    else
      printf '%s\n' "$command_name" >> "$shim_file"
      printf '%s shim added\n' "$command_name"
    fi
  done

  __tb_windows_shim_refresh || return 1
  __tb_windows_path_write_startup_cache || return 1
  __tb_windows_path_apply_startup_cache >/dev/null 2>&1 || true
}

_create_command_wrapper_for_function "include_windows_command"