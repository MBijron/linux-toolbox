#!/bin/bash

clog_background_pid_path() {
    printf '%s/.clog_background.pid\n' "${TBDIR:-/toolbox}"
}

clog_background_is_running() {
    local pid_path
    local background_pid

    pid_path="$(clog_background_pid_path)"
    [[ -f "$pid_path" ]] || return 1

    if ! read -r background_pid < "$pid_path"; then
        rm -f "$pid_path"
        return 1
    fi

    if [[ ! "$background_pid" =~ ^[0-9]+$ ]]; then
        rm -f "$pid_path"
        return 1
    fi

    if kill -0 "$background_pid" 2>/dev/null; then
        return 0
    fi

    rm -f "$pid_path"
    return 1
}

clog_background_start() {
    # Only start if not already running
    if clog_background_is_running; then
        return 0
    fi

    # Check if clog command exists
    if ! command -v clog >/dev/null 2>&1; then
        return 0
    fi

    (
        while true; do
            clog refresh-cache || true
            sleep 3600
        done
    ) &
    echo $! > "$(clog_background_pid_path)"
}

clog_background_stop() {
    local pid_path
    pid_path="$(clog_background_pid_path)"
    if [[ -f "$pid_path" ]]; then
        if read -r background_pid < "$pid_path"; then
            kill "$background_pid" 2>/dev/null || true
        fi
        rm -f "$pid_path"
    fi
}
