#!/bin/bash

c_background_pid_path() {
    printf '%s/.c_background.pid\n' "${TBDIR:-/toolbox}"
}

c_background_is_running() {
    local pid_path
    local background_pid

    pid_path="$(c_background_pid_path)"
    [[ -f "$pid_path" ]] || return 1

    if ! read -r background_pid < "$pid_path"; then
        rm -f "$pid_path"
        return 1
    fi

    if [[ ! "$background_pid" =~ ^[0-9]+$ ]]; then
        rm -f "$pid_path"
        return 1
    fi

    if kill -0 "$background_pid" 2>/dev/null; then
        return 0
    fi

    rm -f "$pid_path"
    return 1
}

c_background_print_cache_failure() {
    local output_target="$1"
    local red=$'\033[0;31m'
    local reset=$'\033[0m'
    local message="c cache update failed"

    if [[ -n "$output_target" && -e "$output_target" ]]; then
        printf '%b%s%b\n' "$red" "$message" "$reset" > "$output_target" 2>/dev/null || true
        return 0
    fi

    printf '%b%s%b\n' "$red" "$message" "$reset" >&2
}

c_background_run_service() {
    local output_target="$1"
    local poll_interval_seconds="5"
    local cache_path
    local previous_root_state=""
    local current_root_state

    cache_path="$(c_cache_path)"

    while true; do
        if ! current_root_state="$(c_capture_repo_map_root_state)"; then
            c_background_print_cache_failure "$output_target"
            sleep "$poll_interval_seconds" || return 0
            continue
        fi

        if [[ ! -f "$cache_path" || "$current_root_state" != "$previous_root_state" ]]; then
            if ! c --update-cache >/dev/null 2>&1; then
                c_background_print_cache_failure "$output_target"
                sleep "$poll_interval_seconds" || return 0
                continue
            fi

            previous_root_state="$current_root_state"
        else
            previous_root_state="$current_root_state"
        fi

        sleep "$poll_interval_seconds" || return 0
    done
}

c_background_start() {
    local pid_path
    local shell_path
    local output_target=""
    local background_pid

    if c_background_is_running; then
        return 0
    fi

    pid_path="$(c_background_pid_path)"
    shell_path="$(command -v bash)"
    [[ -n "$shell_path" ]] || return 1

    if [[ -t 2 ]]; then
        output_target="/proc/$$/fd/2"
    fi

    TOOLBOX_SKIP_BACKGROUND_INIT=1 \
    TOOLBOX_BACKGROUND_OUTPUT_TARGET="$output_target" \
    TBDIR="${TBDIR:-/toolbox}" \
    nohup "$shell_path" -lc 'source "$TBDIR/.core" >/dev/null 2>&1 || exit 1; c_background_run_service "$TOOLBOX_BACKGROUND_OUTPUT_TARGET"' \
        >/dev/null 2>&1 &
    background_pid=$!

    if [[ ! "$background_pid" =~ ^[0-9]+$ ]]; then
        return 1
    fi

    printf '%s\n' "$background_pid" > "$pid_path"
    disown "$background_pid" 2>/dev/null || true
    return 0
}