#!/bin/bash

tcall_wrapper_uses_argument_conversion() {
    local tool_name="$1"
    local wrapper_path
    local first_line
    local second_line

    wrapper_path="$(there_get_first_where_result "$tool_name")" || return $?
    there_validate_wrapper_file "$wrapper_path" || return $?

    first_line="$(sed -n '1p' "$wrapper_path")"
    second_line="$(sed -n '2p' "$wrapper_path")"

    [[ "$first_line" == '#!/bin/bash' && "$second_line" == '# toolbox-windows-shim' ]]
}