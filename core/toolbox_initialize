#!/bin/bash

toolbox_initialize() {
  # Setup bin dir
  local bin_dir="$TBDIR/bin"

  if [[ ! -d "$bin_dir" ]]; then
    mkdir -p "$bin_dir"
  fi

  # Add ~/bin to PATH if it's not already there
  if [[ ":$PATH:" != *":$bin_dir:"* ]]; then
    export PATH="$bin_dir:$PATH"
  fi

  if typeset -f __tb_add_to_path_apply_startup_cache >/dev/null 2>&1; then
    if ! __tb_add_to_path_apply_startup_cache; then
      __tb_add_to_path_refresh_from_tracked_files >/dev/null 2>&1 || true
      __tb_add_to_path_apply_startup_cache >/dev/null 2>&1 || true
    fi
  fi
}