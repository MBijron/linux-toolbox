#!/bin/bash

__tb_add_to_path_cache_path() {
  printf '%s/core/__tb_add_to_path.cache\n' "$TBDIR"
}

__tb_add_to_path_startup_cache_path() {
  printf '%s/core/__tb_add_to_path.startup.cache\n' "$TBDIR"
}

__tb_add_to_path_trim_line() {
  local line="$1"

  line="${line//$'\r'/}"
  line="${line#"${line%%[![:space:]]*}"}"
  line="${line%"${line##*[![:space:]]}"}"

  printf '%s\n' "$line"
}

__tb_add_to_path_normalize_command_name() {
  local command_name=""

  command_name="$(__tb_add_to_path_trim_line "$1")"
  command_name="$(printf '%s' "$command_name" | tr '[:upper:]' '[:lower:]')"

  printf '%s\n' "$command_name"
}

__tb_add_to_path_array_contains() {
  local needle="$1"
  shift
  local value=""

  for value in "$@"; do
    if [ "$value" = "$needle" ]; then
      return 0
    fi
  done

  return 1
}

__tb_add_to_path_find_first_valid_path() {
  local command_name="$1"
  local output=""
  local raw_line=""
  local trimmed_line=""

  output="$(winwhere "$command_name" 2>&1)"

  while IFS= read -r raw_line; do
    trimmed_line="$(__tb_add_to_path_trim_line "$raw_line")"

    if [ -z "$trimmed_line" ]; then
      continue
    fi

    if [ -e "$trimmed_line" ]; then
      printf '%s\n' "$trimmed_line"
      return 0
    fi
  done <<< "$output"

  return 1
}

__tb_windows_command_exists() {
  __tb_add_to_path_find_first_valid_path "$1" >/dev/null 2>&1
}

__tb_windows_alias_target_name() {
  local command_name="$1"
  local suffix=""
  local candidate=""

  for suffix in exe bat cmd; do
    candidate="${command_name}.${suffix}"

    if command -v "$candidate" >/dev/null 2>&1; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}

__tb_add_to_path_cache_loaded="0"
__tb_add_to_path_cache_rows=""

__tb_add_to_path_load_cache() {
  local cache_path=""
  local first_line=""

  if [ "${__tb_add_to_path_cache_loaded:-0}" = "1" ]; then
    return 0
  fi

  __tb_add_to_path_cache_loaded="1"
  __tb_add_to_path_cache_rows=""
  cache_path="$(__tb_add_to_path_cache_path)"

  if [ ! -f "$cache_path" ]; then
    return 0
  fi

  IFS= read -r first_line < "$cache_path" || return 0

  case "$first_line" in
    __tb_add_to_path_cache_rows=*) source "$cache_path" ;;
    *) return 0 ;;
  esac
}

__tb_add_to_path_get_cache_row() {
  local command_name="$1"
  local row=""
  local row_command=""
  local row_status=""
  local row_path=""
  local row_directory=""

  __tb_add_to_path_cache_status=""
  __tb_add_to_path_cache_resolved_path=""
  __tb_add_to_path_cache_directory=""

  __tb_add_to_path_load_cache

  if [ -z "$__tb_add_to_path_cache_rows" ]; then
    return 1
  fi

  while IFS= read -r row || [ -n "$row" ]; do
    IFS=$'\t' read -r row_command row_status row_path row_directory <<< "$row"

    if [ "$row_command" != "$command_name" ]; then
      continue
    fi

    __tb_add_to_path_cache_status="$row_status"
    __tb_add_to_path_cache_resolved_path="$row_path"
    __tb_add_to_path_cache_directory="$row_directory"
    return 0
  done <<< "$__tb_add_to_path_cache_rows"

  return 1
}

__tb_add_to_path_set_cache_row() {
  local command_name="$1"
  local cache_status="$2"
  local resolved_path="$3"
  local directory_path="$4"
  local row=""
  local row_command=""
  local new_rows=""
  local replacement_row=""
  local replaced="0"

  __tb_add_to_path_load_cache
  replacement_row="${command_name}"$'\t'"${cache_status}"$'\t'"${resolved_path}"$'\t'"${directory_path}"

  if [ -n "$__tb_add_to_path_cache_rows" ]; then
    while IFS= read -r row || [ -n "$row" ]; do
      IFS=$'\t' read -r row_command _ <<< "$row"

      if [ "$row_command" = "$command_name" ]; then
        row="$replacement_row"
        replaced="1"
      fi

      if [ -n "$new_rows" ]; then
        new_rows+=$'\n'
      fi

      new_rows+="$row"
    done <<< "$__tb_add_to_path_cache_rows"
  fi

  if [ "$replaced" != "1" ]; then
    if [ -n "$new_rows" ]; then
      new_rows+=$'\n'
    fi

    new_rows+="$replacement_row"
  fi

  __tb_add_to_path_cache_rows="$new_rows"
}

__tb_add_to_path_collect_commands_from_file() {
  local command_file="$1"
  local line=""
  local command_name=""
  local -a commands=()

  if [ ! -s "$command_file" ]; then
    return 0
  fi

  while IFS= read -r line || [ -n "$line" ]; do
    command_name="$(__tb_add_to_path_normalize_command_name "$line")"

    case "$command_name" in
      ''|'#'*) continue ;;
    esac

    if ! __tb_add_to_path_array_contains "$command_name" "${commands[@]}"; then
      commands+=("$command_name")
    fi
  done < "$command_file"

  if [ "${#commands[@]}" -gt 0 ]; then
    printf '%s\n' "${commands[@]}"
  fi
}

__tb_add_to_path_add_directory() {
  local directory_path="$1"

  if [ -z "$directory_path" ] || [ ! -d "$directory_path" ]; then
    return 0
  fi

  if [[ ":$PATH:" == *":$directory_path:"* ]]; then
    return 0
  fi

  export PATH="$directory_path:$PATH"
}

__tb_add_to_path_apply_startup_cache() {
  local startup_cache=""

  startup_cache="$(__tb_add_to_path_startup_cache_path)"
  [ -f "$startup_cache" ] || return 1

  source "$startup_cache"
}

__tb_add_to_path_build_alias_target_from_cache() {
  local command_name="$1"
  local directory_path=""
  local suffix=""
  local candidate_path=""

  if ! __tb_add_to_path_get_cache_row "$command_name"; then
    return 1
  fi

  if [ "$__tb_add_to_path_cache_status" != "found" ] || [ -z "$__tb_add_to_path_cache_directory" ]; then
    return 1
  fi

  directory_path="$__tb_add_to_path_cache_directory"

  for suffix in exe bat cmd; do
    candidate_path="$directory_path/${command_name}.${suffix}"

    if [ -e "$candidate_path" ]; then
      printf '%s.%s\n' "$command_name" "$suffix"
      return 0
    fi
  done

  return 1
}

__tb_add_to_path_write_cache() {
  local cache_path=""
  local temporary_path=""

  cache_path="$(__tb_add_to_path_cache_path)"
  temporary_path="${cache_path}.tmp.$$"

  printf '__tb_add_to_path_cache_rows=%q\n' "$__tb_add_to_path_cache_rows" > "$temporary_path" || return 1
  mv "$temporary_path" "$cache_path"
}

__tb_add_to_path_write_startup_cache() {
  local startup_cache=""
  local temporary_path=""
  local alias_file="$TBDIR/links/include_windows_aliasses.txt"
  local row=""
  local row_status=""
  local row_directory=""
  local line=""
  local command_name=""
  local alias_target=""
  local escaped_directory=""
  local escaped_prefix=""
  local -a unique_directories=()

  __tb_add_to_path_load_cache
  startup_cache="$(__tb_add_to_path_startup_cache_path)"
  temporary_path="${startup_cache}.tmp.$$"

  if [ -n "$__tb_add_to_path_cache_rows" ]; then
    while IFS= read -r row || [ -n "$row" ]; do
      IFS=$'\t' read -r _ row_status _ row_directory <<< "$row"

      if [ "$row_status" != "found" ] || [ -z "$row_directory" ]; then
        continue
      fi

      if ! __tb_add_to_path_array_contains "$row_directory" "${unique_directories[@]}"; then
        unique_directories+=("$row_directory")
      fi
    done <<< "$__tb_add_to_path_cache_rows"
  fi

  {
    printf '#!/bin/bash\n'

    for row_directory in "${unique_directories[@]}"; do
      escaped_directory="$(printf '%q' "$row_directory")"
      escaped_prefix="$(printf '%q' "$row_directory:")"
      printf 'case ":$PATH:" in\n'
      printf '  *:%s:*) ;;\n' "$escaped_directory"
      printf '  *) export PATH=%s"$PATH" ;;\n' "$escaped_prefix"
      printf 'esac\n'
    done

    if [ -s "$alias_file" ]; then
      while IFS= read -r line || [ -n "$line" ]; do
        command_name="$(__tb_add_to_path_normalize_command_name "$line")"

        case "$command_name" in
          ''|'#'*) continue ;;
        esac

        alias_target="$(__tb_add_to_path_build_alias_target_from_cache "$command_name")"

        if [ -n "$alias_target" ]; then
          printf 'alias %s=%q\n' "$command_name" "$alias_target"
        fi
      done < "$alias_file"
    fi
  } > "$temporary_path" || return 1

  mv "$temporary_path" "$startup_cache"
}

__tb_add_to_path_refresh_commands() {
  local command_name=""
  local resolved_path=""
  local directory_path=""

  for command_name in "$@"; do
    resolved_path="$(__tb_add_to_path_find_first_valid_path "$command_name")"

    if [ -n "$resolved_path" ]; then
      directory_path="${resolved_path%/*}"
      __tb_add_to_path_set_cache_row "$command_name" "found" "$resolved_path" "$directory_path"
    else
      __tb_add_to_path_set_cache_row "$command_name" "no path found" "" ""
    fi
  done
}

__tb_add_to_path_refresh_from_tracked_files() {
  local command_file="$TBDIR/links/include_windows_commands.txt"
  local line=""
  local -a commands=()

  while IFS= read -r line; do
    if [ -n "$line" ] && ! __tb_add_to_path_array_contains "$line" "${commands[@]}"; then
      commands+=("$line")
    fi
  done < <(__tb_add_to_path_collect_commands_from_file "$command_file")

  if [ "${#commands[@]}" -eq 0 ]; then
    return 0
  fi

  __tb_add_to_path_refresh_commands "${commands[@]}"
  __tb_add_to_path_write_cache || return 1
  __tb_add_to_path_write_startup_cache || return 1
}

__tb_add_to_path_from_file() {
  local command_file="$1"
  local line=""
  local -a commands=()

  while IFS= read -r line; do
    if [ -n "$line" ] && ! __tb_add_to_path_array_contains "$line" "${commands[@]}"; then
      commands+=("$line")
    fi
  done < <(__tb_add_to_path_collect_commands_from_file "$command_file")

  if [ "${#commands[@]}" -eq 0 ]; then
    return 0
  fi

  __tb_add_to_path "${commands[@]}"
}

__tb_add_to_path_print_help() {
  cat <<'EOF'
Usage: __tb_add_to_path [options] <command> [command ...]

Options:
  -r, --refresh  Refresh the full command cache before adding paths.
  -help, --help  Show this help message.

Each command should be passed as its own argument.
EOF
}

__tb_add_to_path() {
  local refresh_cache="0"
  local command_name=""
  local -a requested_commands=()
  local -a refresh_commands=()

  while [ "$#" -gt 0 ]; do
    case "$1" in
      -r|--refresh)
        refresh_cache="1"
        ;;
      -help|--help)
        __tb_add_to_path_print_help
        return 0
        ;;
      --)
        shift
        continue
        ;;
      -*)
        printf 'Unknown option: %s\n' "$1" >&2
        __tb_add_to_path_print_help >&2
        return 1
        ;;
      *)
        command_name="$(__tb_add_to_path_normalize_command_name "$1")"

        if [ -n "$command_name" ] && ! __tb_add_to_path_array_contains "$command_name" "${requested_commands[@]}"; then
          requested_commands+=("$command_name")
        fi
        ;;
    esac

    shift
  done

  if [ "$refresh_cache" = "1" ]; then
    while IFS= read -r command_name; do
      if [ -n "$command_name" ] && ! __tb_add_to_path_array_contains "$command_name" "${refresh_commands[@]}"; then
        refresh_commands+=("$command_name")
      fi
    done < <(__tb_add_to_path_collect_commands_from_file "$TBDIR/links/include_windows_commands.txt")

    for command_name in "${requested_commands[@]}"; do
      if ! __tb_add_to_path_array_contains "$command_name" "${refresh_commands[@]}"; then
        refresh_commands+=("$command_name")
      fi
    done

    if [ "${#refresh_commands[@]}" -gt 0 ]; then
      __tb_add_to_path_refresh_commands "${refresh_commands[@]}"
      __tb_add_to_path_write_cache || return 1
      __tb_add_to_path_write_startup_cache || return 1
    fi
  else
    for command_name in "${requested_commands[@]}"; do
      if ! __tb_add_to_path_get_cache_row "$command_name"; then
        __tb_add_to_path_refresh_commands "$command_name"
        __tb_add_to_path_get_cache_row "$command_name" >/dev/null 2>&1 || true
      fi

      if [ "$__tb_add_to_path_cache_status" = "found" ]; then
        __tb_add_to_path_add_directory "$__tb_add_to_path_cache_directory"
      fi
    done

    if [ "${#requested_commands[@]}" -gt 0 ]; then
      __tb_add_to_path_write_cache || return 1
      __tb_add_to_path_write_startup_cache || return 1
    fi
  fi

  __tb_add_to_path_apply_startup_cache >/dev/null 2>&1 || true
}
