#!/bin/bash

__tb_windows_path_cache_path() {
  printf '%s/core/windows_path.cache\n' "$TBDIR"
}

__tb_windows_path_startup_cache_path() {
  printf '%s/core/windows_path.startup.cache\n' "$TBDIR"
}

__tb_windows_shim_list_path() {
  printf '%s/links/include_windows_shims.txt\n' "$TBDIR"
}

__tb_windows_shim_manifest_path() {
  printf '%s/core/windows_shims.cache\n' "$TBDIR"
}

__tb_windows_shim_manifest_read_target() {
  local target_command="$1"
  local manifest_path=""
  local command_name=""
  local shim_target=""

  manifest_path="$(__tb_windows_shim_manifest_path)"
  [ -f "$manifest_path" ] || return 1

  while IFS=$'\t' read -r command_name shim_target || [ -n "$command_name" ]; do
    if [ "$command_name" = "$target_command" ] && [ -n "$shim_target" ]; then
      printf '%s\n' "$shim_target"
      return 0
    fi
  done < "$manifest_path"

  return 1
}

__tb_windows_cmd_executable() {
  if [ -x /mnt/c/Windows/System32/cmd.exe ]; then
    printf '/mnt/c/Windows/System32/cmd.exe\n'
    return 0
  fi

  command -v cmd.exe 2>/dev/null || return 1
}

__tb_add_to_path_trim_line() {
  local line="$1"

  line="${line//$'\r'/}"
  line="${line#"${line%%[![:space:]]*}"}"
  line="${line%"${line##*[![:space:]]}"}"

  printf '%s\n' "$line"
}

__tb_add_to_path_normalize_command_name() {
  local command_name=""

  command_name="$(__tb_add_to_path_trim_line "$1")"
  command_name="$(printf '%s' "$command_name" | tr '[:upper:]' '[:lower:]')"

  printf '%s\n' "$command_name"
}

__tb_add_to_path_array_contains() {
  local needle="$1"
  shift
  local value=""

  for value in "$@"; do
    if [ "$value" = "$needle" ]; then
      return 0
    fi
  done

  return 1
}

__tb_add_to_path_find_first_valid_path() {
  local command_name="$1"
  local output=""
  local raw_line=""
  local trimmed_line=""

  output="$(winwhere "$command_name" 2>&1)"

  while IFS= read -r raw_line; do
    trimmed_line="$(__tb_add_to_path_trim_line "$raw_line")"

    if [ -z "$trimmed_line" ]; then
      continue
    fi

    if [ -e "$trimmed_line" ]; then
      printf '%s\n' "$trimmed_line"
      return 0
    fi
  done <<< "$output"

  return 1
}

__tb_windows_command_exists() {
  __tb_add_to_path_find_first_valid_path "$1" >/dev/null 2>&1
}

__tb_windows_path_without_toolbox_bin() {
  local path_value="$1"
  local toolbox_bin="$TBDIR/bin"
  local remaining=""
  local entry=""
  local filtered_path=""

  remaining="$path_value"

  while [ -n "$remaining" ]; do
    case "$remaining" in
      *:*)
        entry="${remaining%%:*}"
        remaining="${remaining#*:}"
        ;;
      *)
        entry="$remaining"
        remaining=""
        ;;
    esac

    if [ -z "$entry" ] || [ "$entry" = "$toolbox_bin" ]; then
      continue
    fi

    filtered_path+="${filtered_path:+:}${entry}"
  done

  printf '%s\n' "$filtered_path"
}

__tb_windows_path_is_windows_entry() {
  case "$1" in
    /mnt/[A-Za-z]/*) return 0 ;;
    *) return 1 ;;
  esac
}

__tb_windows_path_normalize_entry_key() {
  local entry="$1"

  entry="$(__tb_add_to_path_trim_line "$entry")"

  while [ -n "$entry" ] && [ "${entry%/}" != "$entry" ]; do
    entry="${entry%/}"
  done

  printf '%s\n' "$(printf '%s' "$entry" | tr '[:upper:]' '[:lower:]')"
}

__tb_windows_path_compare_key() {
  local entry="$1"

  if __tb_windows_path_is_windows_entry "$entry"; then
    __tb_windows_path_normalize_entry_key "$entry"
    return 0
  fi

  printf '%s\n' "$entry"
}

__tb_windows_path_filter_windows_entries() {
  local path_value="$1"
  local remaining=""
  local entry=""
  local entry_key=""
  local filtered_path=""
  local -a entries=()
  local -a entry_keys=()

  remaining="$path_value"

  while [ -n "$remaining" ]; do
    case "$remaining" in
      *:*)
        entry="${remaining%%:*}"
        remaining="${remaining#*:}"
        ;;
      *)
        entry="$remaining"
        remaining=""
        ;;
    esac

    entry="$(__tb_add_to_path_trim_line "$entry")"
    entry_key="$(__tb_windows_path_normalize_entry_key "$entry")"

    if [ -z "$entry_key" ] || ! __tb_windows_path_is_windows_entry "$entry"; then
      continue
    fi

    if ! __tb_add_to_path_array_contains "$entry_key" "${entry_keys[@]}"; then
      entries+=("$entry")
      entry_keys+=("$entry_key")
    fi
  done

  for entry in "${entries[@]}"; do
    filtered_path+="${filtered_path:+:}${entry}"
  done

  printf '%s\n' "$filtered_path"
}

__tb_windows_path_filter_non_windows_entries() {
  local path_value="$1"
  local remaining=""
  local entry=""
  local entry_key=""
  local filtered_path=""
  local -a entries=()
  local -a entry_keys=()

  remaining="$path_value"

  while [ -n "$remaining" ]; do
    case "$remaining" in
      *:*)
        entry="${remaining%%:*}"
        remaining="${remaining#*:}"
        ;;
      *)
        entry="$remaining"
        remaining=""
        ;;
    esac

    entry="$(__tb_add_to_path_trim_line "$entry")"
    entry_key="$entry"

    if [ -z "$entry_key" ] || __tb_windows_path_is_windows_entry "$entry"; then
      continue
    fi

    if ! __tb_add_to_path_array_contains "$entry_key" "${entry_keys[@]}"; then
      entries+=("$entry")
      entry_keys+=("$entry_key")
    fi
  done

  for entry in "${entries[@]}"; do
    filtered_path+="${filtered_path:+:}${entry}"
  done

  printf '%s\n' "$filtered_path"
}

__tb_windows_path_merge_cached_entries() {
  local current_path="$1"
  local cached_path="$2"
  local remaining=""
  local entry=""
  local entry_key=""
  local merged_path=""
  local -a entries=()
  local -a entry_keys=()

  remaining="$current_path"

  while [ -n "$remaining" ]; do
    case "$remaining" in
      *:*)
        entry="${remaining%%:*}"
        remaining="${remaining#*:}"
        ;;
      *)
        entry="$remaining"
        remaining=""
        ;;
    esac

    entry="$(__tb_add_to_path_trim_line "$entry")"
    entry_key="$(__tb_windows_path_compare_key "$entry")"

    [ -n "$entry_key" ] || continue

    if ! __tb_add_to_path_array_contains "$entry_key" "${entry_keys[@]}"; then
      entries+=("$entry")
      entry_keys+=("$entry_key")
    fi
  done

  remaining="$cached_path"

  while [ -n "$remaining" ]; do
    case "$remaining" in
      *:*)
        entry="${remaining%%:*}"
        remaining="${remaining#*:}"
        ;;
      *)
        entry="$remaining"
        remaining=""
        ;;
    esac

    entry="$(__tb_add_to_path_trim_line "$entry")"
    entry_key="$(__tb_windows_path_normalize_entry_key "$entry")"

    if [ -z "$entry_key" ] || ! __tb_windows_path_is_windows_entry "$entry"; then
      continue
    fi

    if ! __tb_add_to_path_array_contains "$entry_key" "${entry_keys[@]}"; then
      entries+=("$entry")
      entry_keys+=("$entry_key")
    fi
  done

  for entry in "${entries[@]}"; do
    merged_path+="${merged_path:+:}${entry}"
  done

  printf '%s\n' "$merged_path"
}

__tb_windows_shim_target_name() {
  local command_name="$1"
  local path_value="${2:-${__tb_windows_cached_path:-$PATH}}"
  local lookup_path=""
  local suffix=""
  local candidate=""
  local resolved_target=""

  lookup_path="$(__tb_windows_path_without_toolbox_bin "$path_value")"

  for suffix in exe bat cmd; do
    candidate="${command_name}.${suffix}"

    resolved_target="$(PATH="$lookup_path" command -v "$candidate" 2>/dev/null)"
    resolved_target="$(__tb_add_to_path_trim_line "$resolved_target")"

    if [ -n "$resolved_target" ]; then
      printf '%s\n' "$resolved_target"
      return 0
    fi
  done

  return 1
}

__tb_windows_shim_collect_commands() {
  local shim_file=""
  local line=""
  local command_name=""
  local -a commands=()

  shim_file="$(__tb_windows_shim_list_path)"
  [ -s "$shim_file" ] || return 0

  while IFS= read -r line || [ -n "$line" ]; do
    command_name="$(__tb_add_to_path_normalize_command_name "$line")"

    case "$command_name" in
      ''|'#'*) continue ;;
    esac

    if ! __tb_add_to_path_array_contains "$command_name" "${commands[@]}"; then
      commands+=("$command_name")
    fi
  done < "$shim_file"

  if [ "${#commands[@]}" -gt 0 ]; then
    printf '%s\n' "${commands[@]}"
  fi
}

__tb_windows_shim_delete_managed_file() {
  local command_name="$1"
  local shim_path="$TBDIR/bin/$command_name"
  local first_line=""
  local second_line=""

  [ -f "$shim_path" ] || return 0

  IFS= read -r first_line < "$shim_path" || return 0
  IFS= read -r second_line < <(sed -n '2p' "$shim_path") || true

  if [ "$first_line" = '#!/bin/bash' ] && [ "$second_line" = '# toolbox-windows-shim' ]; then
    rm -f "$shim_path"
  fi
}

__tb_windows_shim_delete_managed_variants() {
  local command_name="$1"
  local managed_name=""

  for managed_name in "$command_name" "$command_name.exe" "$command_name.cmd" "$command_name.bat"; do
    __tb_windows_shim_delete_managed_file "$managed_name"
  done
}

__tb_windows_shim_write_file() {
  local shim_name="$1"
  local shim_target="$2"
  local shim_path="$TBDIR/bin/$shim_name"
  local temporary_path="${shim_path}.tmp.$$"

  {
    printf '#!/bin/bash\n'
    printf '# toolbox-windows-shim\n'
    printf 'target=%q\n' "$shim_target"
    printf 'target_command="$target"\n'
    printf 'converted_args=()\n'
    printf 'arg=""\n'
    printf 'converted_arg=""\n'
    printf 'if [ -e "$target" ]; then\n'
    printf '  target_command="$(wslpath -w "$target" 2>/dev/null || printf %%s "$target")"\n'
    printf 'fi\n'
    printf 'for arg in "$@"; do\n'
    printf '  if [ -e "$arg" ]; then\n'
    printf '    converted_arg="$(wslpath -w "$arg" 2>/dev/null || printf %%s "$arg")"\n'
    printf '  else\n'
    printf '    converted_arg="$arg"\n'
    printf '  fi\n'
    printf '  converted_args+=("$converted_arg")\n'
    printf 'done\n'
    printf 'case "$target" in\n'
    printf '  *.cmd|*.bat) exec cmd.exe /d /c "$target_command" "${converted_args[@]}" ;;\n'
    printf '  *) exec "$target" "${converted_args[@]}" ;;\n'
    printf 'esac\n'
  } > "$temporary_path" || return 1

  chmod +x "$temporary_path" || return 1
  mv "$temporary_path" "$shim_path"
}

__tb_windows_shim_write_variants() {
  local command_name="$1"
  local shim_target="$2"
  local extension=""

  __tb_windows_shim_delete_managed_variants "$command_name"
  __tb_windows_shim_write_file "$command_name" "$shim_target" || return 1

  case "$shim_target" in
    *.exe) extension='exe' ;;
    *.cmd) extension='cmd' ;;
    *.bat) extension='bat' ;;
  esac

  if [ -n "$extension" ]; then
    __tb_windows_shim_write_file "$command_name.$extension" "$shim_target" || return 1
  fi
}

__tb_windows_sudo_wrapper_path() {
  printf '%s/bin/sudo\n' "$TBDIR"
}

__tb_windows_write_sudo_wrapper() {
  local wrapper_path=""
  local temporary_path=""

  wrapper_path="$(__tb_windows_sudo_wrapper_path)"
  temporary_path="${wrapper_path}.tmp.$$"

  {
    printf '#!/bin/bash\n'
    printf '# toolbox-sudo-wrapper-v3\n'
    printf 'real_sudo=/usr/bin/sudo\n'
    printf 'real_shell=/usr/bin/zsh\n'
    printf 'toolbox_dir=%q\n' "$TBDIR"
    printf 'toolbox_path="$PATH"\n'
    printf 'sudo_args=()\n'
    printf 'env_args=()\n'
    printf 'command_args=()\n'
    printf 'arg=""\n'
    printf 'expect_value=0\n'
    printf 'passthrough_mode=0\n'
    printf 'command_seen=0\n'
    printf 'if [ ! -x "$real_sudo" ]; then\n'
    printf '  printf "sudo executable not found at %%s\\n" "$real_sudo" >&2\n'
    printf '  exit 1\n'
    printf 'fi\n'
    printf 'if [ ! -x "$real_shell" ]; then\n'
    printf '  real_shell="$(command -v zsh 2>/dev/null || true)"\n'
    printf 'fi\n'
    printf 'if [ -z "$real_shell" ] || [ ! -x "$real_shell" ]; then\n'
    printf '  printf "zsh executable not found for sudo toolbox bootstrap\\n" >&2\n'
    printf '  exit 1\n'
    printf 'fi\n'
    printf 'for arg in "$@"; do\n'
    printf '  if [ "$command_seen" = 1 ]; then\n'
    printf '    command_args+=("$arg")\n'
    printf '    continue\n'
    printf '  fi\n'
    printf '  if [ "$expect_value" = 1 ]; then\n'
    printf '    sudo_args+=("$arg")\n'
    printf '    expect_value=0\n'
    printf '    continue\n'
    printf '  fi\n'
    printf '  case "$arg" in\n'
    printf '    --)\n'
    printf '      sudo_args+=("$arg")\n'
    printf '      command_seen=1\n'
    printf '      ;;\n'
    printf '    -e|--edit|-i|--login|-s|--shell|-l|--list|-v|--validate|-V|--version|-h|--help|-k|--reset-timestamp|-K|--remove-timestamp)\n'
    printf '      passthrough_mode=1\n'
    printf '      sudo_args+=("$arg")\n'
    printf '      ;;\n'
    printf '    -u|-g|-p|-C|-T|-r|-t|-R|-D)\n'
    printf '      sudo_args+=("$arg")\n'
    printf '      expect_value=1\n'
    printf '      ;;\n'
    printf '    --user=*|--group=*|--host=*|--prompt=*|--close-from=*|--command-timeout=*|--role=*|--type=*|--chroot=*|--chdir=*)\n'
    printf '      sudo_args+=("$arg")\n'
    printf '      ;;\n'
    printf '    --user|--group|--host|--prompt|--close-from|--command-timeout|--role|--type|--chroot|--chdir)\n'
    printf '      sudo_args+=("$arg")\n'
    printf '      expect_value=1\n'
    printf '      ;;\n'
    printf '    -*)\n'
    printf '      sudo_args+=("$arg")\n'
    printf '      ;;\n'
    printf '    [A-Za-z_][A-Za-z0-9_]*=*)\n'
    printf '      env_args+=("$arg")\n'
    printf '      ;;\n'
    printf '    *)\n'
    printf '      command_seen=1\n'
    printf '      command_args+=("$arg")\n'
    printf '      ;;\n'
    printf '  esac\n'
    printf 'done\n'
    printf 'if [ "$passthrough_mode" = 1 ] || [ "$expect_value" = 1 ] || [ "${#command_args[@]}" -eq 0 ]; then\n'
    printf '  exec "$real_sudo" "$@"\n'
    printf 'fi\n'
    printf 'exec "$real_sudo" "${sudo_args[@]}" env "PATH=$toolbox_path" "TBDIR=$toolbox_dir" "TOOLBOX_SKIP_BACKGROUND_INIT=1" "${env_args[@]}" "$real_shell" -lc '\''source "$TBDIR/tbr" >/dev/null 2>&1 || exit 1; tbr >/dev/null 2>&1 || true; "$@"'\'' zsh "${command_args[@]}"\n'
  } > "$temporary_path" || return 1

  chmod +x "$temporary_path" || return 1
  mv "$temporary_path" "$wrapper_path"
}

__tb_windows_ensure_sudo_wrapper() {
  local wrapper_path=""
  local first_line=""
  local second_line=""

  wrapper_path="$(__tb_windows_sudo_wrapper_path)"

  if [ -f "$wrapper_path" ]; then
    IFS= read -r first_line < "$wrapper_path" || true
    IFS= read -r second_line < <(sed -n '2p' "$wrapper_path") || true

    if [ "$first_line" = '#!/bin/bash' ] && [ "$second_line" = '# toolbox-sudo-wrapper-v3' ]; then
      return 0
    fi
  fi

  __tb_windows_write_sudo_wrapper
}

__tb_windows_shim_refresh() {
  local manifest_path=""
  local temporary_path=""
  local line=""
  local command_name=""
  local shim_target=""
  local previous_target=""
  local -a previous_commands=()
  local -a tracked_commands=()

  manifest_path="$(__tb_windows_shim_manifest_path)"
  temporary_path="${manifest_path}.tmp.$$"
  rm -f "$TBDIR/links/include_windows_aliasses" "$TBDIR/links/include_windows_aliasses.txt"
  mkdir -p "$TBDIR/bin"
  __tb_windows_ensure_sudo_wrapper || return 1

  if [ -f "$manifest_path" ]; then
    while IFS=$'\t' read -r command_name previous_target || [ -n "$command_name" ]; do
      command_name="$(__tb_add_to_path_normalize_command_name "$command_name")"

      if [ -n "$command_name" ] && ! __tb_add_to_path_array_contains "$command_name" "${previous_commands[@]}"; then
        previous_commands+=("$command_name")
      fi
    done < "$manifest_path"
  fi

  while IFS= read -r line; do
    if [ -n "$line" ] && ! __tb_add_to_path_array_contains "$line" "${tracked_commands[@]}"; then
      tracked_commands+=("$line")
    fi
  done < <(__tb_windows_shim_collect_commands)

  for command_name in "${previous_commands[@]}"; do
    if ! __tb_add_to_path_array_contains "$command_name" "${tracked_commands[@]}"; then
      __tb_windows_shim_delete_managed_variants "$command_name"
    fi
  done

  : > "$temporary_path" || return 1

  for command_name in "${tracked_commands[@]}"; do
    shim_target="$(__tb_windows_shim_target_name "$command_name" "$__tb_windows_cached_path")"

    if [ -z "$shim_target" ]; then
      __tb_windows_shim_delete_managed_variants "$command_name"
      continue
    fi

    __tb_windows_shim_write_variants "$command_name" "$shim_target" || return 1
    printf '%s\t%s\n' "$command_name" "$shim_target" >> "$temporary_path" || return 1
  done

  mv "$temporary_path" "$manifest_path"
}

__tb_windows_shim_repair_missing_from_manifest() {
  local command_name=""
  local shim_target=""
  local unresolved_any="0"

  [ "$#" -gt 0 ] || return 0

  mkdir -p "$TBDIR/bin"
  __tb_windows_ensure_sudo_wrapper || return 1

  for command_name in "$@"; do
    shim_target="$(__tb_windows_shim_manifest_read_target "$command_name")"

    if [ -z "$shim_target" ] || [ ! -e "$shim_target" ]; then
      unresolved_any="1"
      continue
    fi

    __tb_windows_shim_write_variants "$command_name" "$shim_target" || return 1
  done

  if [ "$unresolved_any" = "1" ]; then
    return 2
  fi
}

__tb_windows_shim_refresh_from_cache_if_needed() {
  local shim_file=""
  local line=""
  local command_name=""
  local shim_target=""
  local expected_extension=""
  local repair_result="0"
  local -a missing_commands=()

  shim_file="$(__tb_windows_shim_list_path)"

  __tb_windows_path_load_cache
  [ -n "$__tb_windows_cached_path" ] || return 0

  if [ ! -s "$shim_file" ]; then
    return 0
  fi

  while IFS= read -r line || [ -n "$line" ]; do
    command_name="$(__tb_add_to_path_normalize_command_name "$line")"

    case "$command_name" in
      ''|'#'*) continue ;;
    esac

    shim_target="$(__tb_windows_shim_manifest_read_target "$command_name")"
    expected_extension=""

    case "$shim_target" in
      *.exe) expected_extension='exe' ;;
      *.cmd) expected_extension='cmd' ;;
      *.bat) expected_extension='bat' ;;
    esac

    if [ ! -f "$TBDIR/bin/$command_name" ]; then
      missing_commands+=("$command_name")
      continue
    fi

    if [ -n "$expected_extension" ] && [ ! -f "$TBDIR/bin/$command_name.$expected_extension" ]; then
      missing_commands+=("$command_name")
    fi
  done < "$shim_file"

  if [ "${#missing_commands[@]}" -gt 0 ]; then
    __tb_windows_shim_repair_missing_from_manifest "${missing_commands[@]}"
    repair_result="$?"

    case "$repair_result" in
      0) ;;
      2) return 2 ;;
      *) return 1 ;;
    esac
  fi
}

__tb_windows_path_cache_loaded="0"
__tb_windows_cached_path=""

__tb_windows_path_load_cache() {
  local cache_path=""
  local first_line=""
  local original_path="$PATH"

  if [ "${__tb_windows_path_cache_loaded:-0}" = "1" ]; then
    return 0
  fi

  __tb_windows_path_cache_loaded="1"
  __tb_windows_cached_path=""
  cache_path="$(__tb_windows_path_cache_path)"

  if [ ! -f "$cache_path" ]; then
    return 0
  fi

  IFS= read -r first_line < "$cache_path" || return 0

  case "$first_line" in
    __tb_windows_cached_path=*|export\ PATH=*) source "$cache_path" ;;
    *) return 0 ;;
  esac

  case "$first_line" in
    __tb_windows_cached_path=*) ;;
    *)
      if [ -n "$__tb_windows_cached_path" ]; then
        __tb_windows_cached_path="$(__tb_windows_path_filter_windows_entries "$__tb_windows_cached_path")"
      else
        __tb_windows_cached_path="$(__tb_windows_path_filter_windows_entries "$PATH")"
      fi

      PATH="$original_path"
      ;;
  esac
}

__tb_windows_path_convert_windows_entry() {
  local entry="$1"
  local converted_entry=""

  converted_entry="$(wslpath -u "$entry" 2>/dev/null || true)"

  if [ -n "$converted_entry" ]; then
    printf '%s\n' "$converted_entry"
    return 0
  fi

  if typeset -f udir >/dev/null 2>&1; then
    udir "$entry"
    return 0
  fi

  return 1
}

__tb_windows_path_collect_windows_entries() {
  local cmd_executable=""
  local windows_path=""
  local remaining=""
  local entry=""
  local converted_entry=""
  local -a entries=()

  cmd_executable="$(__tb_windows_cmd_executable)" || return 0
  windows_path="$("$cmd_executable" /d /c echo %PATH% 2>/dev/null | tr -d '\r')"
  remaining="$windows_path"

  while [ -n "$remaining" ]; do
    case "$remaining" in
      *';'*)
        entry="${remaining%%;*}"
        remaining="${remaining#*;}"
        ;;
      *)
        entry="$remaining"
        remaining=""
        ;;
    esac

    entry="$(__tb_add_to_path_trim_line "$entry")"
    [ -n "$entry" ] || continue

    converted_entry="$(__tb_windows_path_convert_windows_entry "$entry")"
    [ -d "$converted_entry" ] || continue

    if ! __tb_add_to_path_array_contains "$converted_entry" "${entries[@]}"; then
      entries+=("$converted_entry")
    fi
  done

  if [ "${#entries[@]}" -gt 0 ]; then
    printf '%s\n' "${entries[@]}"
  fi
}

__tb_windows_path_build_cache() {
  local line=""
  local cached_path=""
  local -a entries=()

  while IFS= read -r line; do
    [ -n "$line" ] || continue

    if ! __tb_add_to_path_array_contains "$line" "${entries[@]}"; then
      entries+=("$line")
    fi
  done < <(__tb_windows_path_collect_windows_entries)

  for line in "${entries[@]}"; do
    cached_path+="${cached_path:+:}${line}"
  done

  printf '%s\n' "$cached_path"
}

__tb_windows_path_apply_startup_cache() {
  local startup_cache=""
  local original_path="$PATH"
  local cached_path=""
  local first_line=""
  local rewrite_startup_cache="0"

  startup_cache="$(__tb_windows_path_startup_cache_path)"
  [ -f "$startup_cache" ] || return 1

  IFS= read -r first_line < "$startup_cache" || return 1

  source "$startup_cache"

  case "$first_line" in
    __tb_windows_cached_path=*) cached_path="$__tb_windows_cached_path" ;;
    *)
      rewrite_startup_cache="1"

      if [ -n "$__tb_windows_cached_path" ]; then
        cached_path="$(__tb_windows_path_filter_windows_entries "$__tb_windows_cached_path")"
      else
        cached_path="$(__tb_windows_path_filter_windows_entries "$PATH")"
      fi

      PATH="$original_path"
      ;;
  esac

  [ -n "$cached_path" ] || return 1

  __tb_windows_cached_path="$cached_path"
  __tb_windows_path_cache_loaded="1"
  __tb_windows_path_apply_loaded_cache "$original_path"

  if [ "$rewrite_startup_cache" = "1" ]; then
    __tb_windows_path_write_startup_cache >/dev/null 2>&1 || true
  fi
}

__tb_windows_path_apply_loaded_cache() {
  local original_path="${1:-$PATH}"
  local linux_path=""
  local -a cached_path_parts=()
  local -a linux_path_parts=()

  [ -n "$__tb_windows_cached_path" ] || return 1

  if [ -n "${ZSH_VERSION:-}" ]; then
    cached_path_parts=("${(@s/:/)__tb_windows_cached_path}")
    linux_path_parts=("${(@)path:#/mnt/[[:alpha:]]/*}")
    path=("${linux_path_parts[@]}" "${cached_path_parts[@]}")
    export PATH
    return 0
  fi

  linux_path="$(__tb_windows_path_filter_non_windows_entries "$original_path")"
  PATH="$(__tb_windows_path_merge_cached_entries "$linux_path" "$__tb_windows_cached_path")"
  export PATH
}

__tb_windows_path_apply_best_available_cache() {
  local original_path="$PATH"

  if __tb_windows_path_apply_startup_cache; then
    return 0
  fi

  __tb_windows_path_cache_loaded="0"
  __tb_windows_path_load_cache

  if [ -n "$__tb_windows_cached_path" ]; then
    __tb_windows_path_apply_loaded_cache "$original_path" || return 1
    __tb_windows_path_write_startup_cache || return 1
    return 0
  fi

  return 1
}

__tb_windows_path_write_cache() {
  local cache_path=""
  local temporary_path=""

  cache_path="$(__tb_windows_path_cache_path)"
  temporary_path="${cache_path}.tmp.$$"

  printf '__tb_windows_cached_path=%q\n' "$__tb_windows_cached_path" > "$temporary_path" || return 1
  mv "$temporary_path" "$cache_path"
}

__tb_windows_path_write_startup_cache() {
  local startup_cache=""
  local temporary_path=""

  startup_cache="$(__tb_windows_path_startup_cache_path)"
  temporary_path="${startup_cache}.tmp.$$"

  {
    printf '__tb_windows_cached_path=%q\n' "$__tb_windows_cached_path"
  } > "$temporary_path" || return 1

  mv "$temporary_path" "$startup_cache"
}

__tb_windows_path_refresh_cache() {
  __tb_windows_cached_path="$(__tb_windows_path_build_cache)"

  if [ -z "$__tb_windows_cached_path" ]; then
    return 1
  fi

  __tb_windows_path_write_cache || return 1
  __tb_windows_path_write_startup_cache || return 1
  __tb_windows_shim_refresh || return 1
  return 0
}

__tb_add_to_path_print_help() {
  cat <<'EOF'
Usage: __tb_add_to_path [options]

Options:
  -r, --refresh-cache  Refresh the full Windows PATH cache.
  -help, --help        Show this help message.
EOF
}

__tb_add_to_path() {
  local refresh_cache="0"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      -r|--refresh-cache)
        refresh_cache="1"
        ;;
      -help|--help)
        __tb_add_to_path_print_help
        return 0
        ;;
      --)
        ;;
      -*)
        printf 'Unknown option: %s\n' "$1" >&2
        __tb_add_to_path_print_help >&2
        return 1
        ;;
      *)
        printf 'Unknown argument: %s\n' "$1" >&2
        __tb_add_to_path_print_help >&2
        return 1
        ;;
    esac

    shift
  done

  __tb_windows_path_load_cache

  if [ "$refresh_cache" = "1" ]; then
    __tb_windows_path_refresh_cache || return 1
  elif ! __tb_windows_path_apply_best_available_cache; then
    __tb_windows_path_refresh_cache || return 1
  else
    return 0
  fi

  __tb_windows_path_apply_startup_cache >/dev/null 2>&1 || true
}
