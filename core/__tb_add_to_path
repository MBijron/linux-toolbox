Usage: __tb_add_to_path [options] <command> [command ...]

Options:
  -r, --refresh  Refresh the full command cache before adding paths.
  -help, --help  Show this help message.

Each command should be passed as its own argument.
EOF
}

__tb_add_to_path() {
  local refresh_cache="0"
  local cache_changed="0"
  local command_name=""
  local lookup_result=""
  local cache_status=""
  local resolved_path=""
  local directory_path=""
  local line=""
  local -a requested_commands=()
  local -a commands_to_refresh=()

  while [ "$#" -gt 0 ]; do
    case "$1" in
      -r|--refresh)
        refresh_cache="1"
        ;;
      -help|--help)
        __tb_add_to_path_print_help
        return 0
        ;;
      --)
        shift
        while [ "$#" -gt 0 ]; do
          command_name="$(__tb_add_to_path_normalize_command_name "$1")"

          if [ -n "$command_name" ] && ! __tb_add_to_path_array_contains "$command_name" "${requested_commands[@]}"; then
            requested_commands+=("$command_name")
          fi

          shift
        done
        break
        ;;
      -*)
        printf 'Unknown option: %s\n' "$1" >&2
        __tb_add_to_path_print_help >&2
        return 1
        ;;
      *)
        command_name="$(__tb_add_to_path_normalize_command_name "$1")"

        if [ -n "$command_name" ] && ! __tb_add_to_path_array_contains "$command_name" "${requested_commands[@]}"; then
          requested_commands+=("$command_name")
        fi
        ;;
    esac

    shift
  done

  __tb_add_to_path_load_cache

  if [ "$refresh_cache" = "1" ]; then
    while IFS= read -r line; do
      if [ -n "$line" ] && ! __tb_add_to_path_array_contains "$line" "${commands_to_refresh[@]}"; then
        commands_to_refresh+=("$line")
      fi
    done < <(__tb_add_to_path_cache_command_names)

    for command_name in "${requested_commands[@]}"; do
      if ! __tb_add_to_path_array_contains "$command_name" "${commands_to_refresh[@]}"; then
        commands_to_refresh+=("$command_name")
      fi
    done

    for command_name in "${commands_to_refresh[@]}"; do
      lookup_result="$(__tb_add_to_path_lookup_command "$command_name")"
      IFS=$'\t' read -r cache_status resolved_path directory_path <<< "$lookup_result"
      __tb_add_to_path_set_cache_row "$command_name" "$cache_status" "$resolved_path" "$directory_path"

      cache_changed="1"
    done
  fi

  for command_name in "${requested_commands[@]}"; do
    if [ "$refresh_cache" != "1" ] && __tb_add_to_path_get_cache_row "$command_name"; then
      cache_status="$__tb_add_to_path_cache_status"
      resolved_path="$__tb_add_to_path_cache_resolved_path"
      directory_path="$__tb_add_to_path_cache_directory"
    else
      lookup_result="$(__tb_add_to_path_lookup_command "$command_name")"
      IFS=$'\t' read -r cache_status resolved_path directory_path <<< "$lookup_result"
      __tb_add_to_path_set_cache_row "$command_name" "$cache_status" "$resolved_path" "$directory_path"
      cache_changed="1"
    fi

    if [ "$cache_status" = "found" ]; then
      __tb_add_to_path_add_directory "$directory_path"
    fi
  done

  if [ "$cache_changed" = "1" ]; then
    __tb_add_to_path_write_cache || return 1
  fi
}