  local refresh_cache="0"
  local command_file=""
  local line=""
  local command_name=""
  local -a commands=()

  if [ "$1" = "--refresh" ]; then
    refresh_cache="1"
    shift
  fi

  command_file="$1"

  if [ ! -f "$command_file" ]; then
    return 0
  fi

  while IFS= read -r line || [ -n "$line" ]; do
