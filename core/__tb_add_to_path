__tb_add_to_path_lookup_command() {
  local command_name="$1"
  local resolved_path=""
  local directory_path=""

  if resolved_path="$(__tb_add_to_path_find_first_valid_path "$command_name")"; then
    directory_path="${resolved_path%/*}"
    printf 'found\t%s\t%s\n' "$resolved_path" "$directory_path"
    return 0
  fi

  printf 'no path found\t\t\n'
  return 1
}

__tb_add_to_path_cache_loaded="0"
__tb_add_to_path_cache_rows=""
__tb_add_to_path_cached_directories=""

__tb_add_to_path_load_cache() {
  local cache_path=""
  local first_line=""

  if [ "${__tb_add_to_path_cache_loaded:-0}" = "1" ]; then
    return 0
  fi

  cache_path="$(__tb_add_to_path_cache_path)"
  __tb_add_to_path_cache_rows=""
  __tb_add_to_path_cached_directories=""
  __tb_add_to_path_cache_loaded="1"

  if [ ! -f "$cache_path" ]; then
    return 0
  fi

  IFS= read -r first_line < "$cache_path" || return 0

  case "$first_line" in
    __tb_add_to_path_cached_directories=*|__tb_add_to_path_cache_rows=*) ;;
    *) return 0 ;;
  esac

  source "$cache_path"
}

__tb_add_to_path_build_cached_directories() {
  local row=""
  local row_status=""
  local row_directory=""
  local directories=""
  local -a unique_directories=()

  __tb_add_to_path_load_cache

  if [ -z "$__tb_add_to_path_cache_rows" ]; then
    return 0
  fi

  while IFS= read -r row || [ -n "$row" ]; do
    IFS=$'\t' read -r _ row_status _ row_directory <<< "$row"

    if [ "$row_status" != "found" ] || [ -z "$row_directory" ]; then
      continue
    fi

    if ! __tb_add_to_path_array_contains "$row_directory" "${unique_directories[@]}"; then
      unique_directories+=("$row_directory")
    fi
  done <<< "$__tb_add_to_path_cache_rows"

  if [ "${#unique_directories[@]}" -eq 0 ]; then
    return 0
  fi

  for row_directory in "${unique_directories[@]}"; do
    if [ -n "$directories" ]; then
      directories+=":"
    fi

    directories+="$row_directory"
  done

  printf '%s\n' "$directories"
}

__tb_add_to_path_apply_cached_directories() {
  local cached_directories=""
  local directory_path=""

  __tb_add_to_path_load_cache
  cached_directories="$__tb_add_to_path_cached_directories"

  if [ -z "$cached_directories" ]; then
    return 1
  fi

  while [ -n "$cached_directories" ]; do
    case "$cached_directories" in
      *:*)
        directory_path="${cached_directories%%:*}"
        cached_directories="${cached_directories#*:}"
        ;;
      *)
        directory_path="$cached_directories"
        cached_directories=""
        ;;
    esac

    __tb_add_to_path_add_directory "$directory_path"
  done

  return 0
}

