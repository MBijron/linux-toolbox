      new_rows+=$'\n'
    fi

    new_rows+="$replacement_row"
  fi

  __tb_add_to_path_cache_rows="$new_rows"
}

__tb_add_to_path_cache_command_names() {
  local row=""
  local row_command=""

  __tb_add_to_path_load_cache

  if [ -z "$__tb_add_to_path_cache_rows" ]; then
    return 0
  fi

  while IFS= read -r row || [ -n "$row" ]; do
