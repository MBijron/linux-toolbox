  temporary_path="${cache_path}.tmp.$$"
  cached_directories="$(__tb_add_to_path_build_cached_directories)"
  __tb_add_to_path_cached_directories="$cached_directories"

  {
    printf '__tb_add_to_path_cached_directories=%q\n' "$cached_directories"
    printf '__tb_add_to_path_cache_rows=%q\n' "$__tb_add_to_path_cache_rows"
  } > "$temporary_path" || return 1

  mv "$temporary_path" "$cache_path"
}

