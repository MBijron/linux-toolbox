#!/bin/bash

alias git="git.exe"

__tb_now_ms() {
  local seconds
  local fraction

  if [ -n "${EPOCHREALTIME:-}" ]; then
    seconds="${EPOCHREALTIME%.*}"
    fraction="${EPOCHREALTIME#*.}000"
    printf '%s%.3s\n' "$seconds" "$fraction"
    return 0
  fi

  date +%s%3N
}

if [ -z "${__tb_start_ms:-}" ]; then
  __tb_start_ms=$(__tb_now_ms)
fi
if [ -z "${__tb_log_count:-}" ]; then
  __tb_log_count=0
fi
__tb_log() {
  local now
  local delta
  now=$(__tb_now_ms)
  delta=$((now - __tb_start_ms))
  if [ $__tb_log_count -eq 0 ]; then
    delta=0
  fi
  __tb_log_count=$((__tb_log_count + 1))
  echo "[tb init ${delta}] $1"
}

__tb_log_bold() {
  printf "\033[1m[tb init %s] %s\033[0m\n" "$(__tb_now_ms)" "$1"
}

__tb_warnings=()

__tb_log_warning() {
  local msg="[tb warn $(__tb_now_ms)] $1"
  __tb_warnings+=("$msg")
  printf "\033[33m%s\033[0m\n" "$msg"
}

__tb_clear() {
  command clear
  if [ ${#__tb_warnings[@]} -gt 0 ]; then
    for msg in "${__tb_warnings[@]}"; do
      printf "\033[33m%s\033[0m\n" "$msg"
    done
  fi
}

reload() {
	source ~/.zshrc
}

__tb_source_fast() {
  local file="$1"

  source "$file"
}

export PATH="/mnt/c/Windows/System32:/mnt/d/Program Files/Microsoft VS Code/bin:/mnt/d/Program Files/Git/cmd:/mnt/d/Visual Studio/Projects/ToolBox/CLI:$PATH"

__tb_toolbox_repo_check_async() {
  local helper_path="$TBDIR/init/tb_repo_check"
  local shell_path
  local output_target=""

  [[ -f "$helper_path" ]] || return 0

  shell_path="$(command -v bash)"
  [[ -n "$shell_path" ]] || return 0

  if [[ -t 2 ]]; then
    output_target="/proc/$$/fd/2"
  fi

  if [[ -n "$ZSH_VERSION" ]]; then
    TBDIR="$TBDIR" TOOLBOX_REPO_OUTPUT_TARGET="$output_target" TB_GIT_CMD="git.exe" \
      nohup "$shell_path" "$helper_path" >/dev/null 2>&1 &!
  else
    TBDIR="$TBDIR" TOOLBOX_REPO_OUTPUT_TARGET="$output_target" TB_GIT_CMD="git.exe" \
      nohup "$shell_path" "$helper_path" >/dev/null 2>&1 &
    disown $! 2>/dev/null || true
  fi
}

__tb_log "Sourcing /toolbox/.env"
__tb_source_fast "/toolbox/.env"

__tb_log "Scheduling toolbox repository check in $TBDIR"
__tb_toolbox_repo_check_async

if [ -f "$TBDIR/tbr" ]; then
  __tb_log "Sourcing $TBDIR/tbr"
  __tb_source_fast "$TBDIR/tbr"
  __tb_log "Running tbr"
  tbr
else
  __tb_log_warning "Toolbox repo is being prepared in the background. Open a new shell when it finishes."
fi

__tb_log "Running toolbox_initialize"
if typeset -f toolbox_initialize >/dev/null 2>&1; then
  toolbox_initialize
fi